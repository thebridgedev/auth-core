{
  "name": "@nebulr-group/bridge-auth-core",
  "version": "0.1.0-beta.3",
  "description": "Framework-agnostic auth core for Bridge platform",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "package": "bun run build && bun pm pack"
  },
  "dependencies": {
    "jose": "^5.2.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {},
  "repository": {
    "type": "git",
    "url": "https://github.com/thebridgedev/auth-core"
  },
  "license": "MIT"
}
